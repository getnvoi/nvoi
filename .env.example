# ── App identity ──────────────────────────────────────────────────────────────
NVOI_APP_NAME=rails
NVOI_ENV=production

# ── Provider selection ────────────────────────────────────────────────────────
COMPUTE_PROVIDER=hetzner
BUILD_PROVIDER=daytona
DNS_PROVIDER=cloudflare
STORAGE_PROVIDER=cloudflare
DNS_ZONE=

# ── Hetzner (compute) ────────────────────────────────────────────────────────
HETZNER_TOKEN=

# ── AWS (compute + storage) ──────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# ── Scaleway (compute + DNS) ─────────────────────────────────────────────────
SCW_SECRET_KEY=
SCW_DEFAULT_ORGANIZATION_ID=

# ── Cloudflare (DNS + R2 storage) ────────────────────────────────────────────
CF_API_KEY=
CF_ZONE_ID=
CF_ACCOUNT_ID=

# ── Docker Hub ────────────────────────────────────────────────────────────────
DOCKER_USERNAME=
DOCKER_PASSWORD=

# ── Build ─────────────────────────────────────────────────────────────────────
DAYTONA_API_KEY=
DAYTONA_API_URL=https://app.daytona.io/api

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=

# ── SSH (path on host — mounted into container as /root/.ssh) ────────────────
SSH_KEY_PATH=~/.ssh/id_ed25519

# ── App secrets ───────────────────────────────────────────────────────────────
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
RAILS_MASTER_KEY=
