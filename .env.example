# ── App identity ──────────────────────────────────────────────────────────────
NVOI_APP_NAME=nvoi
NVOI_ENV=production

# ── Provider selection ────────────────────────────────────────────────────────
COMPUTE_PROVIDER=hetzner
DNS_PROVIDER=cloudflare
STORAGE_PROVIDER=cloudflare
DNS_ZONE=nvoi.to

# ── Hetzner (compute) ────────────────────────────────────────────────────────
HETZNER_TOKEN=

# ── Cloudflare (DNS + R2 storage) ────────────────────────────────────────────
CF_API_KEY=
CF_ZONE_ID=
CF_ACCOUNT_ID=

# ── Deploy secrets (bin/deploy) ───────────────────────────────────────────────
NVOI_POSTGRES_USER=
NVOI_POSTGRES_DB=
NVOI_POSTGRES_PASSWORD=
NVOI_JWT_SECRET=
NVOI_ENCRYPTION_KEY=
