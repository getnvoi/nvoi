# App identity
NVOI_APP_NAME=rails
NVOI_ENV=production

# Provider selection — required, no defaults
COMPUTE_PROVIDER=
BUILD_PROVIDER=
DNS_PROVIDER=
STORAGE_PROVIDER=

# Hetzner (compute)
HETZNER_TOKEN=

# Scaleway (compute + DNS)
SCW_SECRET_KEY=
SCW_DEFAULT_ORGANIZATION_ID=

# Cloudflare (DNS + R2 storage)
CF_API_KEY=
CF_ZONE_ID=
CF_ACCOUNT_ID=

# DNS zone (used by both cloudflare and scaleway DNS)
DNS_ZONE=

# Build (Daytona remote builds)
DAYTONA_API_KEY=
DAYTONA_API_URL=https://app.daytona.io/api

# Build (private repo cloning)
GITHUB_TOKEN=

# SSH (path on host — mounted into container)
SSH_KEY_PATH=~/.ssh/id_ed25519
