# App identity
NVOI_APP_NAME=rails
NVOI_ENV=production

# Provider selection (flag fallbacks)
COMPUTE_PROVIDER=hetzner
BUILD_PROVIDER=local
# DNS_PROVIDER=cloudflare
# STORAGE_PROVIDER=cloudflare

# Compute providers
HETZNER_TOKEN=

# DNS providers
CF_API_KEY=
CF_ZONE_ID=

# Object storage
CF_ACCOUNT_ID=

# Build (Daytona remote builds)
DAYTONA_API_KEY=
DAYTONA_API_URL=https://app.daytona.io/api

# Build (private repo cloning)
GITHUB_TOKEN=

# SSH (path on host — mounted into container)
SSH_KEY_PATH=~/.ssh/id_ed25519
