#!/bin/bash
set -euo pipefail

# ── Hetzner teardown via YAML push ───────────────────────────────────────────
# Push empty config — the diff generates delete steps for everything.

set -a; source examples/.env; set +a

bin/cloud login
bin/cloud repos use dummy-rails

bin/cloud push \
  --config examples/cloud/hetzner-yaml/empty.yaml \
  --env examples/.env \
  --compute-provider hetzner \
  --dns-provider cloudflare \
  --storage-provider cloudflare

bin/cloud deploy
