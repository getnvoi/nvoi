#!/bin/bash
set -euo pipefail

# ── Scaleway teardown via cloud CLI ───────────────────────────────────────────
# Push empty config — the diff generates delete steps for everything.

export COMPUTE_PROVIDER=scaleway
export DNS_PROVIDER=cloudflare
export STORAGE_PROVIDER=cloudflare

bin/cloud push --config examples/cloud/empty.yaml --env examples/.env \
  --compute-provider scaleway --dns-provider cloudflare --storage-provider cloudflare

bin/cloud deploy
