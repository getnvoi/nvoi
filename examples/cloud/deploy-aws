#!/bin/bash
set -euo pipefail

# ── Example: AWS deploy via cloud CLI ─────────────────────────────────────────
# Dev example using the Makefile (cloud mode). Same topology as examples/core/deploy-aws, but through the API.

# nvoi login
make cloud -- login
# nvoi workspaces use default
make cloud -- workspaces use default
# nvoi repos create dummy-rails
make cloud -- repos create dummy-rails
# nvoi repos use dummy-rails
make cloud -- repos use dummy-rails

# nvoi push --config examples/cloud/aws.yaml --env .env --compute-provider aws --dns-provider cloudflare --storage-provider aws --build-provider daytona
make cloud -- push \
  --config examples/cloud/aws.yaml \
  --env .env \
  --compute-provider aws \
  --dns-provider cloudflare \
  --storage-provider aws \
  --build-provider daytona

# nvoi plan
make cloud -- plan
# nvoi deploy
make cloud -- deploy
