#!/bin/bash
set -euo pipefail

# ── Hetzner deploy via cloud CLI ──────────────────────────────────────────────
# Each command mutates the config. deploy executes everything.
# Build targets are resolved at deploy time — no cluster needed before deploy.

set -a; source examples/.env; set +a

bin/cloud login

# ── Providers (workspace-scoped, set once) ──────────────────────────────────

bin/cloud provider set compute hetzner
bin/cloud provider set dns cloudflare
bin/cloud provider set storage cloudflare
bin/cloud provider set build daytona

# ── Repo (link to providers) ──────────────────────────────────────────────────

bin/cloud repos use dummy-rails \
  --compute hetzner --dns cloudflare --storage cloudflare --build daytona

# ── Infrastructure ──────────────────────────────────────────────────────────────

bin/cloud instance set master --compute-type cx23 --compute-region fsn1 --role master
bin/cloud instance set worker-1 --compute-type cx33 --compute-region fsn1 --role worker
bin/cloud firewall set default

# ── Volume ──────────────────────────────────────────────────────────────────────

bin/cloud volume set pgdata --size 20 --server master

# ── Build target (resolved at deploy time) ──────────────────────────────────

bin/cloud build --target web:benbonnet/dummy-rails

# ── Secrets ────────────────────────────────────────────────────────────────────

bin/cloud secret set RAILS_MASTER_KEY "$RAILS_MASTER_KEY"
bin/cloud secret set POSTGRES_PASSWORD "$POSTGRES_PASSWORD"
bin/cloud secret set POSTGRES_USER "$POSTGRES_USER"
bin/cloud secret set POSTGRES_DB "$POSTGRES_DB"

# ── Storage ─────────────────────────────────────────────────────────────────────

bin/cloud storage set assets --cors

# ── Services ────────────────────────────────────────────────────────────────────
# image: "web" references the build target — planner resolves to latest image at deploy time.

bin/cloud service set db \
  --image postgres:17 \
  --port 5432 \
  --volume pgdata:/var/lib/postgresql/data \
  --secret POSTGRES_PASSWORD \
  --secret POSTGRES_USER \
  --secret POSTGRES_DB

bin/cloud service set web \
  --image web \
  --port 80 \
  --replicas 2 \
  --health-path /up \
  --server worker-1 \
  --env RAILS_ENV=production \
  --env POSTGRES_HOST=db \
  --secret POSTGRES_PASSWORD \
  --secret POSTGRES_USER \
  --secret POSTGRES_DB \
  --secret RAILS_MASTER_KEY \
  --storage assets

bin/cloud service set jobs \
  --image web \
  --command "bin/jobs" \
  --server worker-1 \
  --env RAILS_ENV=production \
  --env POSTGRES_HOST=db \
  --secret POSTGRES_PASSWORD \
  --secret POSTGRES_USER \
  --secret POSTGRES_DB \
  --secret RAILS_MASTER_KEY

# ── Ingress + DNS ────────────────────────────────────────────────────────────────

bin/cloud ingress set web:hz-cloud.nvoi.to
bin/cloud dns set web:hz-cloud.nvoi.to

# ── Deploy ───────────────────────────────────────────────────────────────────────

bin/cloud deploy

echo ""
echo "==> done. https://hz-cloud.nvoi.to"
