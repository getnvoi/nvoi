#!/bin/bash
set -euo pipefail

# ── Hetzner deploy via cloud CLI ──────────────────────────────────────────────
# Same topology as examples/core/hetzner/deploy, but through the API.

export COMPUTE_PROVIDER=hetzner
export DNS_PROVIDER=cloudflare
export STORAGE_PROVIDER=cloudflare
export BUILD_PROVIDER=daytona

bin/cloud login
bin/cloud workspaces use default
bin/cloud repos create dummy-rails
bin/cloud repos use dummy-rails

bin/cloud push \
  --config examples/cloud/hetzner/config.yaml \
  --env .env \
  --compute-provider hetzner \
  --dns-provider cloudflare \
  --storage-provider cloudflare \
  --build-provider daytona

bin/cloud plan
bin/cloud deploy
