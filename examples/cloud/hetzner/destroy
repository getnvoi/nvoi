#!/bin/bash
set -euo pipefail

# ── Hetzner teardown via cloud CLI ────────────────────────────────────────────
# Push empty config — the diff generates delete steps for everything.

export COMPUTE_PROVIDER=hetzner
export DNS_PROVIDER=cloudflare
export STORAGE_PROVIDER=cloudflare

bin/cloud push --config examples/cloud/empty.yaml --env .env \
  --compute-provider hetzner --dns-provider cloudflare --storage-provider cloudflare

bin/cloud deploy
