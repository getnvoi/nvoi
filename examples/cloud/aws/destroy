#!/bin/bash
set -euo pipefail

# ── AWS teardown via cloud CLI ────────────────────────────────────────────────
# Push empty config — the diff generates delete steps for everything.

export COMPUTE_PROVIDER=aws
export DNS_PROVIDER=cloudflare
export STORAGE_PROVIDER=aws

bin/cloud push --config examples/cloud/empty.yaml --env .env \
  --compute-provider aws --dns-provider cloudflare --storage-provider aws

bin/cloud deploy
