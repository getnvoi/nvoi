#!/bin/bash
set -euo pipefail

# ── AWS deploy via cloud CLI ──────────────────────────────────────────────────
# Same topology as examples/core/aws/deploy, but through the API.

export COMPUTE_PROVIDER=aws
export DNS_PROVIDER=cloudflare
export STORAGE_PROVIDER=aws
export BUILD_PROVIDER=daytona

bin/cloud login
bin/cloud workspaces use default
bin/cloud repos create dummy-rails

bin/cloud push \
  --config examples/cloud/aws/config.yaml \
  --env .env \
  --compute-provider aws \
  --dns-provider cloudflare \
  --storage-provider aws \
  --build-provider daytona

bin/cloud plan
bin/cloud deploy
