#!/bin/bash
set -euo pipefail

# ── Example: Scaleway deploy via cloud CLI ────────────────────────────────────
# Dev example using the Makefile (cloud mode). Same topology as examples/core/deploy-scaleway, but through the API.

# nvoi login
make cloud -- login
# nvoi workspaces use default
make cloud -- workspaces use default
# nvoi repos create dummy-rails
make cloud -- repos create dummy-rails
# nvoi repos use dummy-rails
make cloud -- repos use dummy-rails

# nvoi push --config examples/cloud/scaleway.yaml --env .env --compute-provider scaleway --dns-provider cloudflare --storage-provider cloudflare --build-provider daytona
make cloud -- push \
  --config examples/cloud/scaleway.yaml \
  --env .env \
  --compute-provider scaleway \
  --dns-provider cloudflare \
  --storage-provider cloudflare \
  --build-provider daytona

# nvoi plan
make cloud -- plan
# nvoi deploy
make cloud -- deploy
