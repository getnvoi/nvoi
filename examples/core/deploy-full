#!/bin/bash
set -euo pipefail

# ── Example: fully explicit deploy sequence ──────────────────────────────────
# Every command declares all options inline — no env vars required.
# Showcases the complete CLI interface for direct binary invocation.

echo "==> deploying rails (production) — fully explicit"

# ── Infrastructure ──────────────────────────────────────────────────────────────

nvoi instance set master \
  --app-name rails \
  --environment production \
  --compute-provider hetzner \
  --compute-credentials HETZNER_TOKEN=$HETZNER_TOKEN \
  --compute-type cx23 \
  --compute-region fsn1

nvoi instance set worker-1 \
  --app-name rails \
  --environment production \
  --compute-provider hetzner \
  --compute-credentials HETZNER_TOKEN=$HETZNER_TOKEN \
  --compute-type cx33 \
  --compute-region fsn1 \
  --worker

nvoi volume set pgdata \
  --app-name rails \
  --environment production \
  --compute-provider hetzner \
  --compute-credentials HETZNER_TOKEN=$HETZNER_TOKEN \
  --size 30 \
  --server master

nvoi volume set meili-data \
  --app-name rails \
  --environment production \
  --compute-provider hetzner \
  --compute-credentials HETZNER_TOKEN=$HETZNER_TOKEN \
  --size 20 \
  --server master

# ── Build ───────────────────────────────────────────────────────────────────────

nvoi build \
  --app-name rails \
  --environment production \
  --compute-provider hetzner \
  --compute-credentials HETZNER_TOKEN=$HETZNER_TOKEN \
  --build-provider daytona \
  --build-credentials api_key=$DAYTONA_API_KEY \
  --source benbonnet/dummy-rails \
  --name web \
  --git-token "$GITHUB_TOKEN"

WEB_IMAGE=$(nvoi build latest web \
  --app-name rails \
  --environment production \
  --compute-provider hetzner \
  --compute-credentials HETZNER_TOKEN=$HETZNER_TOKEN)

echo "image: $WEB_IMAGE"

# ── Secrets ─────────────────────────────────────────────────────────────────────

nvoi secret set RAILS_MASTER_KEY "$RAILS_MASTER_KEY" \
  --app-name rails \
  --environment production \
  --compute-provider hetzner \
  --compute-credentials HETZNER_TOKEN=$HETZNER_TOKEN

nvoi secret set POSTGRES_PASSWORD "$POSTGRES_PASSWORD" \
  --app-name rails \
  --environment production \
  --compute-provider hetzner \
  --compute-credentials HETZNER_TOKEN=$HETZNER_TOKEN

# ── Storage ─────────────────────────────────────────────────────────────────────

nvoi storage set assets \
  --app-name rails \
  --environment production \
  --compute-provider hetzner \
  --compute-credentials HETZNER_TOKEN=$HETZNER_TOKEN \
  --storage-provider cloudflare \
  --cors

# ── Services ────────────────────────────────────────────────────────────────────

nvoi service set db \
  --app-name rails \
  --environment production \
  --compute-provider hetzner \
  --compute-credentials HETZNER_TOKEN=$HETZNER_TOKEN \
  --image postgres:17 \
  --volume pgdata:/var/lib/postgresql/data \
  --env POSTGRES_USER="$POSTGRES_USER" \
  --env POSTGRES_DB="$POSTGRES_DB" \
  --secret POSTGRES_PASSWORD

nvoi service set meilisearch \
  --app-name rails \
  --environment production \
  --compute-provider hetzner \
  --compute-credentials HETZNER_TOKEN=$HETZNER_TOKEN \
  --image getmeili/meilisearch:latest \
  --volume meili-data:/meili_data

nvoi service set web \
  --app-name rails \
  --environment production \
  --compute-provider hetzner \
  --compute-credentials HETZNER_TOKEN=$HETZNER_TOKEN \
  --image "$WEB_IMAGE" \
  --port 80 \
  --replicas 2 \
  --health-path /up \
  --server worker-1 \
  --env RAILS_ENV=production \
  --env POSTGRES_HOST=db \
  --env POSTGRES_USER="$POSTGRES_USER" \
  --env POSTGRES_DB="$POSTGRES_DB" \
  --secret POSTGRES_PASSWORD \
  --secret RAILS_MASTER_KEY \
  --storage assets

nvoi service set jobs \
  --app-name rails \
  --environment production \
  --compute-provider hetzner \
  --compute-credentials HETZNER_TOKEN=$HETZNER_TOKEN \
  --image "$WEB_IMAGE" \
  --command "bin/jobs" \
  --server worker-1 \
  --env RAILS_ENV=production \
  --env POSTGRES_HOST=db \
  --env POSTGRES_USER="$POSTGRES_USER" \
  --env POSTGRES_DB="$POSTGRES_DB" \
  --secret POSTGRES_PASSWORD \
  --secret RAILS_MASTER_KEY

# ── DNS ─────────────────────────────────────────────────────────────────────────

nvoi dns set web final.nvoi.to \
  --app-name rails \
  --environment production \
  --compute-provider hetzner \
  --compute-credentials HETZNER_TOKEN=$HETZNER_TOKEN \
  --dns-provider cloudflare \
  --zone nvoi.to

# ── Verify ──────────────────────────────────────────────────────────────────────

nvoi show \
  --app-name rails \
  --environment production \
  --compute-provider hetzner \
  --compute-credentials HETZNER_TOKEN=$HETZNER_TOKEN

echo ""
echo "==> done. https://final.nvoi.to"
