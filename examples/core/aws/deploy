#!/bin/bash
set -euo pipefail

# ── Example: AWS deploy sequence ─────────────────────────────────────────────
# Dev example using the Makefile. AWS compute (EC2) + storage (S3). Cloudflare DNS.
# Requires NVOI_APP_NAME, NVOI_ENV, and provider credentials as env vars.

set -a; source .env; set +a

export COMPUTE_PROVIDER=aws
export DNS_PROVIDER=cloudflare
export STORAGE_PROVIDER=aws
export BUILD_PROVIDER=daytona

# ── Infrastructure ──────────────────────────────────────────────────────────────

# nvoi instance set master --compute-type t3.medium --compute-region eu-west-3
$CLI instance set master --compute-type t3.medium --compute-region eu-west-3
# nvoi volume set pgdata --size 30 --server master
$CLI volume set pgdata --size 30 --server master

# ── Build ───────────────────────────────────────────────────────────────────────

# nvoi build --source benbonnet/dummy-rails --name web
$CLI build --source benbonnet/dummy-rails --name web

# WEB_IMAGE=$(nvoi build latest web)
WEB_IMAGE=$($CLI build latest web)

# ── Secrets ─────────────────────────────────────────────────────────────────────

# nvoi secret set RAILS_MASTER_KEY "$RAILS_MASTER_KEY"
$CLI secret set RAILS_MASTER_KEY "$RAILS_MASTER_KEY"
# nvoi secret set POSTGRES_PASSWORD "$POSTGRES_PASSWORD"
$CLI secret set POSTGRES_PASSWORD "$POSTGRES_PASSWORD"

# ── Storage ─────────────────────────────────────────────────────────────────────

# nvoi storage set assets --cors
$CLI storage set assets --cors

# ── Services ────────────────────────────────────────────────────────────────────

# nvoi service set db --image postgres:17 --volume pgdata:/var/lib/postgresql/data --env POSTGRES_USER="$POSTGRES_USER" --env POSTGRES_DB="$POSTGRES_DB" --secret POSTGRES_PASSWORD
$CLI service set db \
  --image postgres:17 \
  --volume pgdata:/var/lib/postgresql/data \
  --env POSTGRES_USER="$POSTGRES_USER" \
  --env POSTGRES_DB="$POSTGRES_DB" \
  --secret POSTGRES_PASSWORD

# nvoi service set web --image "$WEB_IMAGE" --port 80 --replicas 2 --health-path /up --env RAILS_ENV=production --env POSTGRES_HOST=db --env POSTGRES_USER="$POSTGRES_USER" --env POSTGRES_DB="$POSTGRES_DB" --secret POSTGRES_PASSWORD --secret RAILS_MASTER_KEY --storage assets
$CLI service set web \
  --image "$WEB_IMAGE" \
  --port 80 \
  --replicas 2 \
  --health-path /up \
  --env RAILS_ENV=production \
  --env POSTGRES_HOST=db \
  --env POSTGRES_USER="$POSTGRES_USER" \
  --env POSTGRES_DB="$POSTGRES_DB" \
  --secret POSTGRES_PASSWORD \
  --secret RAILS_MASTER_KEY \
  --storage assets

# nvoi service set jobs --image "$WEB_IMAGE" --command "bin/jobs" --env RAILS_ENV=production --env POSTGRES_HOST=db --env POSTGRES_USER="$POSTGRES_USER" --env POSTGRES_DB="$POSTGRES_DB" --secret POSTGRES_PASSWORD --secret RAILS_MASTER_KEY
$CLI service set jobs \
  --image "$WEB_IMAGE" \
  --command "bin/jobs" \
  --env RAILS_ENV=production \
  --env POSTGRES_HOST=db \
  --env POSTGRES_USER="$POSTGRES_USER" \
  --env POSTGRES_DB="$POSTGRES_DB" \
  --secret POSTGRES_PASSWORD \
  --secret RAILS_MASTER_KEY

# ── DNS ──────────────────────────────────────────────────────────────────────────

# nvoi dns set web final.nvoi.to
$CLI dns set web aws.nvoi.to

echo ""
echo "==> done. https://aws.nvoi.to"
