#!/bin/bash
set -euo pipefail

# ── Scaleway deploy ───────────────────────────────────────────────────────────
# 1 server, postgres, web, jobs. Scaleway compute. Cloudflare DNS + R2.

set -a; source examples/.env; set +a

export COMPUTE_PROVIDER=scaleway
export DNS_PROVIDER=cloudflare
export STORAGE_PROVIDER=cloudflare
export BUILD_PROVIDER=daytona

# ── Infrastructure ──────────────────────────────────────────────────────────────

bin/core instance set master --compute-type DEV1-L --compute-region fr-par-1 --role master
bin/core firewall set default

# ── Build ───────────────────────────────────────────────────────────────────────

bin/core build --target web:benbonnet/dummy-rails
WEB_IMAGE=$(bin/core build latest web)

# ── Secrets ─────────────────────────────────────────────────────────────────────

bin/core secret set RAILS_MASTER_KEY "$RAILS_MASTER_KEY"
bin/core secret set POSTGRES_PASSWORD "$POSTGRES_PASSWORD"
bin/core secret set POSTGRES_USER "$POSTGRES_USER"
bin/core secret set POSTGRES_DB "$POSTGRES_DB"

# ── Storage ─────────────────────────────────────────────────────────────────────

bin/core storage set assets --cors

# ── Services ────────────────────────────────────────────────────────────────────

bin/core service set db \
  --image postgres:17 \
  --port 5432 \
  --volume pgdata:/var/lib/postgresql/data \
  --secret POSTGRES_PASSWORD \
  --secret POSTGRES_USER \
  --secret POSTGRES_DB

bin/core service set web \
  --image "$WEB_IMAGE" \
  --port 80 \
  --replicas 2 \
  --health-path /up \
  --env RAILS_ENV=production \
  --env POSTGRES_HOST=db \
  --secret POSTGRES_PASSWORD \
  --secret POSTGRES_USER \
  --secret POSTGRES_DB \
  --secret RAILS_MASTER_KEY \
  --storage assets

bin/core service set jobs \
  --image "$WEB_IMAGE" \
  --command "bin/jobs" \
  --env RAILS_ENV=production \
  --env POSTGRES_HOST=db \
  --secret POSTGRES_PASSWORD \
  --secret POSTGRES_USER \
  --secret POSTGRES_DB \
  --secret RAILS_MASTER_KEY

# ── Ingress + DNS ────────────────────────────────────────────────────────────────

bin/core ingress set web:scw.nvoi.to
bin/core dns set web:scw.nvoi.to

echo ""
echo "==> done. https://scw.nvoi.to"
