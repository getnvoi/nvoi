#!/bin/bash
set -euo pipefail

# ── Hetzner deploy ────────────────────────────────────────────────────────────
# 2 servers, managed postgres with backups, web, jobs. Cloudflare DNS + R2.

set -a; source examples/.env; set +a

export COMPUTE_PROVIDER=hetzner
export DNS_PROVIDER=cloudflare
export STORAGE_PROVIDER=cloudflare
export BUILD_PROVIDER=daytona

# ── Infrastructure ──────────────────────────────────────────────────────────────

bin/core instance set master --compute-type cx23 --compute-region fsn1 --role master
bin/core instance set worker-1 --compute-type cx33 --compute-region fsn1 --role worker
bin/core firewall set cloudflare

# ── Build ───────────────────────────────────────────────────────────────────────

bin/core build --target web:benbonnet/dummy-rails
WEB_IMAGE=$(bin/core build latest web)

# ── Secrets ─────────────────────────────────────────────────────────────────────

bin/core secret set RAILS_MASTER_KEY "$RAILS_MASTER_KEY"
bin/core secret set POSTGRES_PASSWORD "$POSTGRES_PASSWORD"
bin/core secret set POSTGRES_USER "$POSTGRES_USER"
bin/core secret set POSTGRES_DB "$POSTGRES_DB"

# ── Storage ─────────────────────────────────────────────────────────────────────

bin/core storage set assets --cors
bin/core storage set db-backups --expire-days 30

# ── Managed database ───────────────────────────────────────────────────────────

bin/core database set db --type postgres \
  --secret POSTGRES_PASSWORD \
  --secret POSTGRES_USER \
  --secret POSTGRES_DB \
  --backup-storage db-backups \
  --backup-cron "0 2 * * *"

# ── Services ────────────────────────────────────────────────────────────────────

bin/core service set web \
  --image "$WEB_IMAGE" \
  --port 80 \
  --replicas 2 \
  --health-path /up \
  --server worker-1 \
  --env RAILS_ENV=production \
  --env POSTGRES_HOST=db \
  --secret POSTGRES_PASSWORD \
  --secret POSTGRES_USER \
  --secret POSTGRES_DB \
  --secret RAILS_MASTER_KEY \
  --storage assets

bin/core service set jobs \
  --image "$WEB_IMAGE" \
  --command "bin/jobs" \
  --server worker-1 \
  --env RAILS_ENV=production \
  --env POSTGRES_HOST=db \
  --secret POSTGRES_PASSWORD \
  --secret POSTGRES_USER \
  --secret POSTGRES_DB \
  --secret RAILS_MASTER_KEY

# ── Ingress + DNS ────────────────────────────────────────────────────────────────

bin/core ingress set web:hz.nvoi.to --cloudflare-managed
bin/core dns set web:hz.nvoi.to --cloudflare-managed

echo ""
echo "==> done. https://hz.nvoi.to"
