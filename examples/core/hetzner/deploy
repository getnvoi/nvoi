#!/bin/bash
set -euo pipefail

# ── Hetzner deploy ────────────────────────────────────────────────────────────
# 2 servers, 2 volumes, meilisearch, postgres, web, jobs. Cloudflare DNS + R2.

set -a; source .env; set +a

export COMPUTE_PROVIDER=hetzner
export DNS_PROVIDER=cloudflare
export STORAGE_PROVIDER=cloudflare
export BUILD_PROVIDER=daytona

# ── Infrastructure ──────────────────────────────────────────────────────────────

bin/core instance set master --compute-type cx23 --compute-region fsn1
bin/core instance set worker-1 --compute-type cx33 --compute-region fsn1 --worker
bin/core volume set pgdata --size 30 --server master
bin/core volume set meili-data --size 20 --server master

# ── Build ───────────────────────────────────────────────────────────────────────

bin/core build --source benbonnet/dummy-rails --name web
WEB_IMAGE=$(bin/core build latest web)

# ── Secrets ─────────────────────────────────────────────────────────────────────

bin/core secret set RAILS_MASTER_KEY "$RAILS_MASTER_KEY"
bin/core secret set POSTGRES_PASSWORD "$POSTGRES_PASSWORD"

# ── Storage ─────────────────────────────────────────────────────────────────────

bin/core storage set assets --cors

# ── Services ────────────────────────────────────────────────────────────────────

bin/core service set db \
  --image postgres:17 \
  --volume pgdata:/var/lib/postgresql/data \
  --env POSTGRES_USER="$POSTGRES_USER" \
  --env POSTGRES_DB="$POSTGRES_DB" \
  --secret POSTGRES_PASSWORD

bin/core service set meilisearch \
  --image getmeili/meilisearch:latest \
  --volume meili-data:/meili_data

bin/core service set web \
  --image "$WEB_IMAGE" \
  --port 80 \
  --replicas 2 \
  --health-path /up \
  --server worker-1 \
  --env RAILS_ENV=production \
  --env POSTGRES_HOST=db \
  --env POSTGRES_USER="$POSTGRES_USER" \
  --env POSTGRES_DB="$POSTGRES_DB" \
  --secret POSTGRES_PASSWORD \
  --secret RAILS_MASTER_KEY \
  --storage assets

bin/core service set jobs \
  --image "$WEB_IMAGE" \
  --command "bin/jobs" \
  --server worker-1 \
  --env RAILS_ENV=production \
  --env POSTGRES_HOST=db \
  --env POSTGRES_USER="$POSTGRES_USER" \
  --env POSTGRES_DB="$POSTGRES_DB" \
  --secret POSTGRES_PASSWORD \
  --secret RAILS_MASTER_KEY

# ── DNS ──────────────────────────────────────────────────────────────────────────

bin/core dns set web hz.nvoi.to

echo ""
echo "==> done. https://hz.nvoi.to"
