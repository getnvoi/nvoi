#!/bin/bash
set -euo pipefail

# ── Example: teardown sequence ───────────────────────────────────────────────
# Dev example using the Makefile. Reverse order of deploy. Every delete is idempotent — tolerates missing resources.
# Requires NVOI_APP_NAME, NVOI_ENV, and provider credentials as env vars.

echo "==> destroying $NVOI_APP_NAME ($NVOI_ENV)"

# ── Teardown (reverse order of deploy) ──────────────────────────────────────

# nvoi dns delete web final.nvoi.to -y
make cli -- dns delete web final.nvoi.to -y
# nvoi storage empty assets -y
make cli -- storage empty assets -y
# nvoi storage delete assets -y
make cli -- storage delete assets -y
# nvoi secret delete RAILS_MASTER_KEY
make cli -- secret delete RAILS_MASTER_KEY
# nvoi secret delete POSTGRES_PASSWORD
make cli -- secret delete POSTGRES_PASSWORD
# nvoi service delete jobs -y
make cli -- service delete jobs -y
# nvoi service delete web -y
make cli -- service delete web -y
# nvoi service delete meilisearch -y
make cli -- service delete meilisearch -y
# nvoi service delete db -y
make cli -- service delete db -y
# nvoi volume delete meili-data -y
make cli -- volume delete meili-data -y
# nvoi volume delete pgdata -y
make cli -- volume delete pgdata -y
# nvoi instance delete worker-1 -y
make cli -- instance delete worker-1 -y
# nvoi instance delete master -y
make cli -- instance delete master -y

echo ""
echo "==> destroyed."
