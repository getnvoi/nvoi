#!/bin/bash
set -euo pipefail

# ── Example: provider router ─────────────────────────────────────────────────
# Dev example using the Makefile. Reads COMPUTE_PROVIDER and delegates to the matching deploy script.
# Requires COMPUTE_PROVIDER as an env var (e.g. hetzner, aws, scaleway).

if [ -z "${COMPUTE_PROVIDER:-}" ]; then
  echo "COMPUTE_PROVIDER is required."
  echo "  COMPUTE_PROVIDER=hetzner"
  echo "  COMPUTE_PROVIDER=aws"
  echo "  COMPUTE_PROVIDER=scaleway"
  exit 1
fi

SCRIPT="deploy-${COMPUTE_PROVIDER}"
if [ ! -x "$SCRIPT" ]; then
  echo "No deploy script for provider: $COMPUTE_PROVIDER (expected $SCRIPT)"
  exit 1
fi

exec "$SCRIPT" "$@"
