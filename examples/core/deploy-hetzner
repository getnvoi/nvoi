#!/bin/bash
set -euo pipefail

# ── Example: Hetzner deploy sequence ───────────────────────────────────────────
# Hetzner compute. Cloudflare DNS + storage (R2).
# Requires NVOI_APP_NAME, NVOI_ENV, and provider credentials as env vars.

# ── Infrastructure ──────────────────────────────────────────────────────────────

nvoi instance set master --compute-type cx23 --compute-region fsn1
nvoi instance set worker-1 --compute-type cx33 --compute-region fsn1 --worker
nvoi volume set pgdata --size 30 --server master
nvoi volume set meili-data --size 20 --server master

# ── Build ───────────────────────────────────────────────────────────────────────

nvoi build --source benbonnet/dummy-rails --name web

WEB_IMAGE=$(nvoi build latest web)

# ── Secrets ─────────────────────────────────────────────────────────────────────

nvoi secret set RAILS_MASTER_KEY "$RAILS_MASTER_KEY"
nvoi secret set POSTGRES_PASSWORD "$POSTGRES_PASSWORD"

# ── Storage ─────────────────────────────────────────────────────────────────────

nvoi storage set assets --cors

# ── Services ────────────────────────────────────────────────────────────────────

nvoi service set db \
  --image postgres:17 \
  --volume pgdata:/var/lib/postgresql/data \
  --env POSTGRES_USER="$POSTGRES_USER" \
  --env POSTGRES_DB="$POSTGRES_DB" \
  --secret POSTGRES_PASSWORD

nvoi service set meilisearch \
  --image getmeili/meilisearch:latest \
  --volume meili-data:/meili_data

nvoi service set web \
  --image "$WEB_IMAGE" \
  --port 80 \
  --replicas 2 \
  --health-path /up \
  --server worker-1 \
  --env RAILS_ENV=production \
  --env POSTGRES_HOST=db \
  --env POSTGRES_USER="$POSTGRES_USER" \
  --env POSTGRES_DB="$POSTGRES_DB" \
  --secret POSTGRES_PASSWORD \
  --secret RAILS_MASTER_KEY \
  --storage assets

nvoi service set jobs \
  --image "$WEB_IMAGE" \
  --command "bin/jobs" \
  --server worker-1 \
  --env RAILS_ENV=production \
  --env POSTGRES_HOST=db \
  --env POSTGRES_USER="$POSTGRES_USER" \
  --env POSTGRES_DB="$POSTGRES_DB" \
  --secret POSTGRES_PASSWORD \
  --secret RAILS_MASTER_KEY

# ── DNS ──────────────────────────────────────────────────────────────────────────

nvoi dns set web final.nvoi.to

echo ""
echo "==> done. https://final.nvoi.to"
