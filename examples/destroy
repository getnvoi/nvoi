#!/bin/bash
set -euo pipefail

MODE="${1:?usage: ./examples/destroy <core|cloud> <hetzner|aws|scaleway>}"
PROVIDER="${2:?usage: ./examples/destroy <core|cloud> <hetzner|aws|scaleway>}"
SCRIPT="examples/${MODE}/${PROVIDER}/destroy"

if [ ! -f "$SCRIPT" ]; then
  echo "no destroy script: $SCRIPT"
  exit 1
fi

set -a; source .env; set +a

if [ "$MODE" = "core" ]; then
  export CLI="docker compose run --rm -e COMPUTE_PROVIDER -e DNS_PROVIDER -e STORAGE_PROVIDER -e BUILD_PROVIDER core"
elif [ "$MODE" = "cloud" ]; then
  export CLI="docker compose run --rm -e COMPUTE_PROVIDER -e DNS_PROVIDER -e STORAGE_PROVIDER -e BUILD_PROVIDER cli"
else
  echo "mode must be core or cloud"
  exit 1
fi

exec bash "$SCRIPT"
