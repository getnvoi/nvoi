#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
WEB="$ROOT/cmd/web"
PORT="${PORT:-3000}"

# Kill anything already on the port
if lsof -ti:"$PORT" >/dev/null 2>&1; then
  echo "killing stale process on :$PORT"
  lsof -ti:"$PORT" | xargs kill -9 2>/dev/null
  sleep 1
fi

# Ensure CSS deps
[ -d "$WEB/node_modules" ] || (cd "$WEB" && npm install --silent >&2)

# Initial CSS build (so output.css is never empty on first load)
(cd "$WEB" && npx @tailwindcss/cli -i static/css/input.css -o static/css/output.css) >&2

# Tailwind CSS watcher (background)
(cd "$WEB" && npx @tailwindcss/cli -i static/css/input.css -o static/css/output.css --watch) &
CSS_PID=$!
trap "kill $CSS_PID 2>/dev/null" EXIT

# Air: Go hot reload (foreground)
cd "$ROOT"
exec air -c .air.web.toml
