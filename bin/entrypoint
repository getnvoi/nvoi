#!/bin/sh
set -e

# Start Docker daemon if privileged (DinD for local builder)
if [ -e /dev/kvm ] || [ -w /var/run ]; then
  if ! docker info >/dev/null 2>&1; then
    dockerd --storage-driver=vfs >/dev/null 2>&1 &
    # Wait for daemon
    for i in $(seq 1 30); do
      docker info >/dev/null 2>&1 && break
      sleep 1
    done
  fi
fi

exec go run ./cmd/core "$@"
