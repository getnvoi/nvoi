#!/bin/sh
set -e

# Start Docker daemon if privileged (DinD for local builder)
if [ -e /dev/kvm ] || [ -w /var/run ]; then
  if ! docker info >/dev/null 2>&1; then
    dockerd --storage-driver=vfs >/dev/null 2>&1 &
    # Wait for daemon
    for i in $(seq 1 30); do
      docker info >/dev/null 2>&1 && break
      sleep 1
    done
  fi
fi

# Build once, run fast. Binary cached in bin-cache volume.
BIN=/app/tmp/nvoi
if [ ! -f "$BIN" ] || [ "$(find /app/pkg /app/internal /app/cmd -newer "$BIN" -print -quit 2>/dev/null)" ]; then
  go build -o "$BIN" ./cmd/cli >&2
fi

exec "$BIN" "$@"
