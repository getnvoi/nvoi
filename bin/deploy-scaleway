#!/bin/bash
set -euo pipefail

# ── Scaleway deploy ──────────────────────────────────────────────────────────
# Scaleway compute + DNS. Cloudflare storage (R2).
# Everything comes from .env — provider selection, credentials, app secrets.
# Compose loads .env into the container. Source it here too so deploy
# script vars ($RAILS_MASTER_KEY, $POSTGRES_PASSWORD, etc.) expand on the host.

set -a
source .env
set +a

# ── Infrastructure ──────────────────────────────────────────────────────────────

bin/cli instance set master --compute-type DEV1-L --compute-region fr-par-1
bin/cli volume set pgdata --size 30 --server master

# ── Build ───────────────────────────────────────────────────────────────────────

bin/cli build --source benbonnet/dummy-rails --name web

WEB_IMAGE=$(bin/cli build latest web)

# ── Secrets ─────────────────────────────────────────────────────────────────────

bin/cli secret set RAILS_MASTER_KEY "$RAILS_MASTER_KEY"
bin/cli secret set POSTGRES_PASSWORD "$POSTGRES_PASSWORD"

# ── Storage ─────────────────────────────────────────────────────────────────────

bin/cli storage set assets --cors

# ── Services ────────────────────────────────────────────────────────────────────

bin/cli service set db \
  --image postgres:17 \
  --volume pgdata:/var/lib/postgresql/data \
  --env POSTGRES_USER="$POSTGRES_USER" \
  --env POSTGRES_DB="$POSTGRES_DB" \
  --secret POSTGRES_PASSWORD

bin/cli service set web \
  --image "$WEB_IMAGE" \
  --port 80 \
  --replicas 2 \
  --health-path /up \
  --env RAILS_ENV=production \
  --env POSTGRES_HOST=db \
  --env POSTGRES_USER="$POSTGRES_USER" \
  --env POSTGRES_DB="$POSTGRES_DB" \
  --secret POSTGRES_PASSWORD \
  --secret RAILS_MASTER_KEY \
  --storage assets

bin/cli service set jobs \
  --image "$WEB_IMAGE" \
  --command "bin/jobs" \
  --env RAILS_ENV=production \
  --env POSTGRES_HOST=db \
  --env POSTGRES_USER="$POSTGRES_USER" \
  --env POSTGRES_DB="$POSTGRES_DB" \
  --secret POSTGRES_PASSWORD \
  --secret RAILS_MASTER_KEY

# ── DNS ──────────────────────────────────────────────────────────────────────────

bin/cli dns set web scw.nvoi.to

echo ""
echo "==> done. https://scw.nvoi.to"
