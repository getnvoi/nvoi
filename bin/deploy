#!/bin/bash
set -euo pipefail

# ── Env-var path ──────────────────────────────────────────────────────────────
# All provider + identity config lives in env vars via compose:
#   .env          → credentials (HETZNER_TOKEN, DAYTONA_API_KEY, etc.)
#                 → provider selection (COMPUTE_PROVIDER, BUILD_PROVIDER, etc.)
#                 → app identity (NVOI_APP_NAME, NVOI_ENV)
#   environment:  → passes them into the container
#
# This script only sources .env.deploy for app secrets (DB creds, etc.)
# and calls bin/cli — which runs inside compose with everything already set.

set -a
source .env.deploy
set +a

echo "==> deploying ${NVOI_APP_NAME:-rails} (${NVOI_ENV:-production})"

# ── Infrastructure ──────────────────────────────────────────────────────────────

bin/cli instance set master --compute-type cx23 --compute-region fsn1
bin/cli instance set worker-1 --compute-type cx33 --compute-region fsn1 --worker
bin/cli volume set pgdata --size 30 --server master
bin/cli volume set meili-data --size 20 --server master

# ── Build ───────────────────────────────────────────────────────────────────────

bin/cli build --source benbonnet/dummy-rails --name web

WEB_IMAGE=$(bin/cli build latest web)

echo "image: $WEB_IMAGE"

# ── Services ────────────────────────────────────────────────────────────────────

bin/cli service set db \
  --image postgres:17 \
  --volume pgdata:/var/lib/postgresql/data \
  --env POSTGRES_USER="$POSTGRES_USER" \
  --env POSTGRES_PASSWORD="$POSTGRES_PASSWORD" \
  --env POSTGRES_DB="$POSTGRES_DB"

bin/cli service set meilisearch \
  --image getmeili/meilisearch:latest \
  --volume meili-data:/meili_data

bin/cli service set web \
  --image "$WEB_IMAGE" \
  --port 80 \
  --replicas 2 \
  --health-path /up \
  --server worker-1 \
  --env RAILS_ENV=production \
  --env POSTGRES_HOST=db \
  --env POSTGRES_USER="$POSTGRES_USER" \
  --env POSTGRES_PASSWORD="$POSTGRES_PASSWORD" \
  --env POSTGRES_DB="$POSTGRES_DB"

bin/cli service set jobs \
  --image "$WEB_IMAGE" \
  --command "bin/jobs" \
  --server worker-1 \
  --env RAILS_ENV=production \
  --env POSTGRES_HOST=db \
  --env POSTGRES_USER="$POSTGRES_USER" \
  --env POSTGRES_PASSWORD="$POSTGRES_PASSWORD" \
  --env POSTGRES_DB="$POSTGRES_DB"

# ── Secrets ─────────────────────────────────────────────────────────────────────

bin/cli secret set RAILS_MASTER_KEY "$RAILS_MASTER_KEY"

# ── Storage ─────────────────────────────────────────────────────────────────────

bin/cli storage set assets --storage-provider cloudflare --bucket nvoi-dummy-rails-assets --cors

# ── DNS ─────────────────────────────────────────────────────────────────────────

bin/cli dns set web final.nvoi.to --dns-provider cloudflare --zone nvoi.to

# ── Deploy ──────────────────────────────────────────────────────────────────────

bin/cli apply
bin/cli show

echo ""
echo "==> done. https://final.nvoi.to"
