#!/bin/bash
set -euo pipefail

# ── Provider router ──────────────────────────────────────────────────────────
# Reads COMPUTE_PROVIDER from .env and delegates to bin/deploy-{provider}.

# Source .env so the router knows which provider without host exports.
set -a
source .env
set +a

if [ -z "${COMPUTE_PROVIDER:-}" ]; then
  echo "COMPUTE_PROVIDER is required. Set it in .env."
  echo "  COMPUTE_PROVIDER=hetzner"
  echo "  COMPUTE_PROVIDER=aws"
  echo "  COMPUTE_PROVIDER=scaleway"
  exit 1
fi

SCRIPT="bin/deploy-${COMPUTE_PROVIDER}"
if [ ! -x "$SCRIPT" ]; then
  echo "No deploy script for provider: $COMPUTE_PROVIDER (expected $SCRIPT)"
  exit 1
fi

exec "$SCRIPT" "$@"
