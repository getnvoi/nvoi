#!/bin/bash
set -euo pipefail

# ── NVOI_ENV is the differentiator ─────────────────────────────────────────────
# Different NVOI_ENV = brand new infrastructure.
#   NVOI_ENV=production  → nvoi-production-*
#   NVOI_ENV=staging     → nvoi-staging-*

export NVOI_APP_NAME=${NVOI_APP_NAME:-rails}
export NVOI_ENV=${NVOI_ENV:-production}

# Load credentials
set -a
source .env.deploy
set +a

echo "==> deploying $NVOI_APP_NAME ($NVOI_ENV)"

# ── Infrastructure ──────────────────────────────────────────────────────────────

bin/cli compute set master --provider hetzner --type cax11 --region fsn1
bin/cli compute set worker-1 --provider hetzner --type cax21 --region fsn1 --worker
bin/cli volume set pgdata --provider hetzner --size 20 --server master
# bin/cli volume set meili-data --provider hetzner --size 10 --server master

# ── Services ────────────────────────────────────────────────────────────────────

