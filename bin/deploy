#!/bin/bash
set -euo pipefail

# ── Provider router ──────────────────────────────────────────────────────────
# Delegates to bin/deploy-{provider} based on COMPUTE_PROVIDER env var.

if [ -z "${COMPUTE_PROVIDER:-}" ]; then
  echo "COMPUTE_PROVIDER is required. Set it in .env or export it."
  echo "  export COMPUTE_PROVIDER=hetzner"
  echo "  export COMPUTE_PROVIDER=scaleway"
  echo "  export COMPUTE_PROVIDER=aws"
  exit 1
fi

case "$COMPUTE_PROVIDER" in
  hetzner)
    exec bin/deploy-hetzner "$@"
    ;;
  scaleway)
    exec bin/deploy-scaleway "$@"
    ;;
  aws)
    exec bin/deploy-aws "$@"
    ;;
  *)
    echo "Unknown COMPUTE_PROVIDER: $COMPUTE_PROVIDER (expected: hetzner, scaleway, aws)"
    exit 1
    ;;
esac
