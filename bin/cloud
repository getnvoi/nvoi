#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Start API + postgres if not running
if ! docker compose -f "$ROOT_DIR/docker-compose.yml" ps --status running 2>/dev/null | grep -q api; then
  echo "starting api + postgres..."
  docker compose -f "$ROOT_DIR/docker-compose.yml" up -d --wait
fi

export NVOI_API_BASE="http://localhost:8080"

exec go run ./cmd/cli "$@"
